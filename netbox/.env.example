# Netbox Environment Variables
# Generated on: $(date)

# Django secret key
# SECRET_KEY: Secret key for Django application (used for cryptographic signing)
SECRET_KEY=your_secret_key_here

# Database credentials
# DB_PASSWORD: Password for Netbox database user
DB_PASSWORD=your_db_password_here

# Redis credentials
# REDIS_PASSWORD: Password for Redis task queue
REDIS_PASSWORD=your_redis_password_here

# REDIS_CACHE_PASSWORD: Password for Redis cache
REDIS_CACHE_PASSWORD=your_redis_cache_password_here
